# ─────────────────────────────────────────────────────────────
# NetGuard Environment Variables
# Copy this file to .env and edit the values
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────

# Required API key for protected backend routes
NETGUARD_API_KEY=change-me

# Allowed frontend origins (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Optional data root override (contains flows.db, passive_timeline.db, temp_uploads/)
# NETGUARD_DATA_DIR=/absolute/path/to/data/root
DATABASE_URL=sqlite:///
DATA_RETENTION_DAYS=30
ALERT_FINAL_SCORE_THRESHOLD=70
ALERT_CORRELATION_WINDOW_MINUTES=10
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# OSINT / Threat Intelligence
# ─────────────────────────────────────────────────────────────
# Set these in your environment (or copy to .env) to enable OSINT validation.
OSINT_ENABLED=true
OSINT_CACHE_TTL_SECONDS=3600
OSINT_MAX_RETRIES=2
OSINT_SKIP_NON_PUBLIC_IPS=true

# API Keys (do not commit real keys)
ABUSEIPDB_API_KEY=
VIRUSTOTAL_API_KEY=
